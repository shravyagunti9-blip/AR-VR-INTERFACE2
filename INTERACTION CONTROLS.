<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AR Interaction Controls</title>

<style>
body{
    margin:0;
    overflow:hidden;
    font-family: Arial;
    background:black;
}

/* Demo background */
#background{
    width:100%;
    height:100vh;
    object-fit:cover;
    position:fixed;
    z-index:-1;
}

/* Furniture object */
#object{
    position:absolute;
    top:40%;
    left:40%;
    width:200px;
    cursor:grab;
    user-select:none;
    transition:transform 0.1s linear;
}

/* Control panel */
.controls{
    position:fixed;
    bottom:0;
    width:100%;
    background:rgba(0,0,0,0.7);
    color:white;
    padding:15px;
    text-align:center;
}

input{
    width:150px;
}
</style>
</head>

<body>

<!-- Background image (simulate camera) -->
<img id="background" src="https://images.unsplash.com/photo-1505691938895-1758d7feb511">

<!-- Furniture Object -->
<img id="object" src="https://pngimg.com/uploads/sofa/sofa_PNG6941.png">

<!-- Controls -->
<div class="controls">
    Rotate:
    <input type="range" id="rotate" min="0" max="360" value="0">

    Resize:
    <input type="range" id="resize" min="50" max="300" value="100">
</div>

<script>
const object = document.getElementById("object");
const rotate = document.getElementById("rotate");
const resize = document.getElementById("resize");

let rotation = 0;
let scale = 1;

/* Update Transform */
function updateTransform(){
    object.style.transform =
        `rotate(${rotation}deg) scale(${scale})`;
}

/* Rotate Control */
rotate.addEventListener("input", ()=>{
    rotation = rotate.value;
    updateTransform();
});

/* Resize Control */
resize.addEventListener("input", ()=>{
    scale = resize.value / 100;
    updateTransform();
});

/* Move (Drag) */
let isDragging = false;
let offsetX, offsetY;

object.addEventListener("mousedown", (e)=>{
    isDragging = true;
    offsetX = e.clientX - object.offsetLeft;
    offsetY = e.clientY - object.offsetTop;
    object.style.cursor = "grabbing";
});

document.addEventListener("mousemove", (e)=>{
    if(isDragging){
        object.style.left = (e.clientX - offsetX) + "px";
        object.style.top = (e.clientY - offsetY) + "px";
    }
});

document.addEventListener("mouseup", ()=>{
    isDragging = false;
    object.style.cursor = "grab";
});
</script>

</body>
</html>
